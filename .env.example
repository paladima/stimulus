# Database (MySQL/TiDB)
DATABASE_URL=mysql://user:password@host:port/database

# Admin Authentication
JWT_SECRET=your-jwt-secret-here
ADMIN_DEFAULT_PASSWORD=change-me-on-first-login

# Contact Form Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL_TO=leads@only-fans.ai

# Site URL (for sitemap, hreflang canonical URLs)
NEXT_PUBLIC_SITE_URL=https://only-fans.ai

# Railway sets PORT automatically, no need to configure
# PORT=3000
